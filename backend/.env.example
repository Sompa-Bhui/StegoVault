# StegoVault Environment Variables

# Backend
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=sqlite:///./stegovault.db

# Storage
UPLOAD_DIR=./uploads
ENCODED_DIR=./encoded_images
DECODED_DIR=./decoded_data

# Admin (Initial setup)
ADMIN_USER=admin
ADMIN_PASSWORD=admin-password
